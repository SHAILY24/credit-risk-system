# Database Configuration
POSTGRES_PASSWORD=change-this-secure-password
DATABASE_URL=postgresql://creditrisk:change-this-secure-password@postgres:5432/creditrisk_db

# Redis Configuration  
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:change-this-redis-password@redis:6379/0

# Security
SECRET_KEY=change-this-to-a-very-secure-secret-key-use-openssl-rand-hex-32

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# Monitoring (optional)
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-this-grafana-password

# Model Configuration
MODEL_PATH=/app/credit_risk_model.pkl